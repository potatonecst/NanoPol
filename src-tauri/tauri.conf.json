{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nanopol",
  "version": "0.1.0",
  "identifier": "com.neirotakada.nanopol",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NanoPol",
        "width": 800,
        "height": 850,
        "minWidth": 425,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/backend"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}